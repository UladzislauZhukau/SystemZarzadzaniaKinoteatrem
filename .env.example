# PostgreSQL
POSTGRES_DB=kinoteatr
POSTGRES_USER=admin
POSTGRES_PASSWORD=secret

# Backend database connection (used inside Docker network)
DATABASE_URL=postgresql+psycopg2://admin:secret@db:5432/kinoteatr

# JWT
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS (frontend origin)
FRONTEND_ORIGIN=http://localhost:3000

# OMDb API (IMDb data) - get a free key at https://www.omdbapi.com/apikey.aspx
# Used by the admin "Szukaj w IMDb" film autofill feature.
OMDB_API_KEY=

# TMDb API (trailers) - get a free key at https://www.themoviedb.org/settings/api
# Used to fetch a YouTube trailer for the film during admin lookup.
TMDB_API_KEY=d0ba895775d3a52470f3780f9e164d20

# Email (SMTP). For development you can use a fake/console setup.
# MAIL_SUPPRESS_SEND=true disables actually sending emails (useful for local dev/tests).
MAIL_SUPPRESS_SEND=true
MAIL_USERNAME=your@email.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=no-reply@example.com
MAIL_FROM_NAME=Kinoteatr
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_STARTTLS=true
MAIL_SSL_TLS=false
